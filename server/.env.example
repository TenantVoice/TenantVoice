# ─── Supabase ───────────────────────────────────────────────────────────────────
# Get this from: Supabase Dashboard → Project → Settings → Database → URI
# Use the "Session pooler" connection string (port 5432, not 6543)
PG_CONNECTION_STRING=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ─── Session ────────────────────────────────────────────────────────────────────
# Any long random string — used to sign the session cookie
SESSION_SECRET=change_me_to_something_long_and_random

# ─── App ────────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
